# ============================================
# Agentic Documentation System - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Atlassian / Confluence
CONFLUENCE_SITE=pikachu28.atlassian.net
CONFLUENCE_SPACE_KEY=ED1
CONFLUENCE_PAGE_ID=688129
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=your-atlassian-api-token

# n8n
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/doc-sync
N8N_AUTH_TOKEN=your-secret-auth-token

# Google Gemini (used by n8n for diff-to-XHTML conversion)
GEMINI_API_KEY=your-gemini-api-key
